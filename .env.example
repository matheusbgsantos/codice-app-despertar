# Banco de dados SQLite — caminho absoluto ou relativo ao diretório de execução.
# Exemplo: /app/data/app.db  ou  ./data/app.db
DATABASE_URL=/app/data/app.db

# Segredo para assinar os JWTs de sessão. Use uma string longa e aleatória.
JWT_SECRET=troque_por_um_segredo_forte_e_aleatorio

# Token de autenticação dos webhooks enviados pela Kirvano.
KIRVANO_WEBHOOK_TOKEN=troque_pelo_token_do_webhook_kirvano

# Porta em que o servidor HTTP vai escutar (padrão: 3000).
PORT=3000
